# Urban Terror Optimized — normalisation des fins de ligne
* text=auto eol=lf

# Sources C/C++ : LF
*.c    text eol=lf
*.h    text eol=lf

# Scripts
*.sh   text eol=lf

# Fichiers Windows : CRLF
*.bat  text eol=crlf
*.sln  text eol=crlf
*.vcxproj text eol=crlf

# Binaires (pas de conversion)
*.pk3  binary
*.png  binary
*.jpg  binary
*.wav  binary
*.bsp  binary
*.aas  binary
