{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make:*)", "Bash(bear:*)", "Bash(ccache:*)", "Bash(cmake:*)",
      "Bash(git:*)", "Bash(gh:*)", "Bash(rg:*)", "Bash(fd:*)",
      "Bash(clang-format:*)", "Bash(clang-tidy:*)", "Bash(cppcheck:*)", "Bash(ctags:*)"
    ],
    "deny": ["Bash(git push:*)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command",
            "command": "bash -c 'f=$(jq -r \".tool_input.file_path // empty\"); case \"$f\" in *.c|*.h) command -v git >/dev/null 2>&1 && git clang-format -f -- \"$f\" >/dev/null 2>&1 || true ;; esac'" }
        ]
      }
    ]
  }
}
